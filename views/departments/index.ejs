<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">Departments List</h2>
        <a href="/departments/new" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add New Department
        </a>
    </div>

    <% if (departments.length===0) { %>
        <div class="alert alert-warning">No departments found.</div>
        <% } else { %>

            <table class="table table-bordered table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Department Name</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <% departments.forEach((dept, index)=> { %>
                        <tr>
                            <td>
                                <%= index + 1 %>
                            </td>
                            <td>
                                <%= dept.name %>
                            </td>

                            <td>
                                <a href="/departments/<%= dept._id %>/edit" class="btn btn-primary btn-sm">
                                    Edit
                                </a>

                                <form action="/departments/<%= dept._id %>?_method=DELETE" method="POST"
                                    class="d-inline">
                                    <button class="btn btn-danger btn-sm"
                                        onclick="return confirm('Delete this department?')">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>

            <% } %>

</div>